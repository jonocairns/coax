{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coax.invalid/schemas/windows-mpv-runtime-v1.json",
  "title": "Coax pinned Windows mpv runtime",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "target",
    "artifact",
    "source",
    "selectedAt",
    "notes"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "status": { "const": "pinned" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "arch"],
      "properties": {
        "platform": { "const": "win32" },
        "arch": { "const": "x64" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "fileName", "sha256", "sizeBytes", "releaseUrl"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "fileName": { "type": "string", "pattern": "^[^/]+\\.7z$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "sizeBytes": { "type": "integer", "minimum": 1 },
        "releaseUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstreamInstallationUrl",
        "buildProjectUrl",
        "buildProjectCommit",
        "buildProjectSourceUrl",
        "workflowUrl",
        "mpvRepositoryUrl",
        "mpvCommit",
        "mpvSourceUrl",
        "ffmpegRepositoryUrl",
        "ffmpegCommit",
        "ffmpegSourceUrl",
        "buildConfiguration"
      ],
      "properties": {
        "upstreamInstallationUrl": { "type": "string", "format": "uri" },
        "buildProjectUrl": { "type": "string", "format": "uri" },
        "buildProjectCommit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "buildProjectSourceUrl": { "type": "string", "format": "uri" },
        "workflowUrl": { "type": "string", "format": "uri" },
        "mpvRepositoryUrl": { "type": "string", "format": "uri" },
        "mpvCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "mpvSourceUrl": { "type": "string", "format": "uri" },
        "ffmpegRepositoryUrl": { "type": "string", "format": "uri" },
        "ffmpegCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "ffmpegSourceUrl": { "type": "string", "format": "uri" },
        "buildConfiguration": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workflow",
            "compiler",
            "targetTriplet",
            "cpuBaseline",
            "cmakeOptions",
            "mpvOptions",
            "ffmpegLicenseOptions",
            "artifactFlavor"
          ],
          "properties": {
            "workflow": { "type": "string", "minLength": 1 },
            "compiler": { "type": "string", "minLength": 1 },
            "targetTriplet": { "const": "x86_64-w64-mingw32" },
            "cpuBaseline": { "const": "x86-64" },
            "cmakeOptions": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "mpvOptions": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "ffmpegLicenseOptions": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "artifactFlavor": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "selectedAt": { "type": "string", "format": "date-time" },
    "notes": { "type": "string", "minLength": 1 }
  }
}
